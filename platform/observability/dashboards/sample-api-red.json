{
  "dashboard": {
    "id": null,
    "uid": "nexus-sample-api-red",
    "title": "NEXUS Sample API — RED",
    "tags": ["nexus", "sample-api", "red"],
    "timezone": "utc",
    "schemaVersion": 36,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Rate (requests/sec)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=\"sample-api\"}[5m]))",
            "legendFormat": "Requests/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Errors (%)",
        "type": "stat",
        "targets": [
          {
            "expr": "100 * (sum(rate(http_requests_total{job=\"sample-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"sample-api\"}[5m])))",
            "legendFormat": "Error %"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0}
      },
      {
        "id": 3,
        "title": "Duration (p95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"sample-api\"}[5m])) by (le))",
            "legendFormat": "p95 latency"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0}
      }
    ]
  }
}
